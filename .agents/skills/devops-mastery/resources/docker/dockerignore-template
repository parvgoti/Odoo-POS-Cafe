# =============================================
# .dockerignore Template
# =============================================
# Place this file in your project root.
# Keeps Docker context small and secure.
# =============================================

# Version control
.git
.gitignore
.gitattributes

# Dependencies (will be installed fresh in container)
node_modules
.pnp
.pnp.js

# Build artifacts
dist
build
.next
.nuxt
.output
.cache
.parcel-cache

# Environment files (secrets!)
.env
.env.*
!.env.example

# IDE / Editor
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Testing
coverage
.nyc_output
__tests__
**/*.test.js
**/*.test.ts
**/*.spec.js
**/*.spec.ts
jest.config.*
vitest.config.*

# Documentation (not needed in container)
*.md
!README.md
docs
LICENSE
CHANGELOG*

# Docker
Dockerfile*
docker-compose*
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.circleci

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
*.tmp
*.temp

# Python
__pycache__
*.pyc
*.pyo
.mypy_cache
.pytest_cache
.venv
venv
env

# Misc
*.tgz
*.tar.gz
backups
tmp
